generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  name     String
  lastName String?  @map("last_name")
  userName String   @map("user_name")
  email    String   @unique
  role     UserRole @default(REGULAR)
  password String

  sessions Session[] @relation("User_sessions_Session_User")

  avatar Avatar? @relation("User_avatar_Avatar_user")

  createdGroups Group[] @relation("User_createdGroups_Group_owner")

  inGroups GroupMember[] @relation("User_inGroups_GroupMember_userId")

  createdTasks Task[] @relation("User_createdTasks_Tasks_creatorId")

  assignedTasks Task[] @relation("User_assignedTasks_Tasks_assigneeId")

  notifications Notification[] @relation("User_notifications_Notification_user")

  skills Skill[] @relation("User_skills_Skill_userId")

  badges Badge[] @relation("Badge_userId_User_badges")

  messages Message[] @relation("Message_sender_User_messages")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  expiresAt  DateTime @map("expires_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")

  token String @unique

  ip        String?
  userAgent String? @map("user_agent")

  user   User   @relation("User_sessions_Session_User", fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("sessions")
}

model Group {
  id String @id @default(uuid())

  name     String
  isPublic Boolean @default(true) @map("is_public")

  owner   User?   @relation("User_createdGroups_Group_owner", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @map("owner_id")

  projects Project[] @relation("Group_projects_Project_inGroup")

  members GroupMember[] @relation("Group_members_GroupMember_inGroup")

  messages Message[] @relation("Message_group_Group_messages")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@map("groups")
}

model GroupMember {
  id String @id @default(uuid())

  type MemberType @default(MEMBER)

  user   User?   @relation("User_inGroups_GroupMember_userId", fields: [userId], references: [id], onDelete: SetNull)
  userId String? @map("user_id")

  inGroup   Group?  @relation("Group_members_GroupMember_inGroup", fields: [inGroupId], references: [id], onDelete: SetNull)
  inGroupId String? @map("in_group_id")

  @@unique([userId, inGroupId])
  @@map("group_members")
}

model Project {
  id String @id @default(uuid())

  name     String
  isPublic Boolean @default(true) @map("is_public")

  group   Group  @relation("Group_projects_Project_inGroup", fields: [groupId], references: [id], onDelete: Cascade)
  groupId String @map("group_id")

  tasks Task[] @relation("Project_tasks_Task_inProject")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@map("projects")
}

model Task {
  id String @id @default(uuid())

  title       String?
  description String?
  text        String
  expiresAt   DateTime @map("expires_at")

  images Image[] @relation("Task_images_Image_task")

  inProject   Project @relation("Project_tasks_Task_inProject", fields: [inProjectId], references: [id], onDelete: Cascade)
  inProjectId String  @map("in_project_id")

  creator   User   @relation("User_createdTasks_Tasks_creatorId", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String @map("creator_id")

  assignee   User?   @relation("User_assignedTasks_Tasks_assigneeId", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId String? @map("assignee_id")

  status   TaskStatus   @default(TODO)
  priority TaskPriority @default(MEDIUM)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tasks")
}

model Notification {
  id String @id @default(uuid())

  text   String
  isRead Boolean          @default(false) @map("is_read")
  type   NotificationType

  user   User   @relation("User_notifications_Notification_user", fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("notifications")
}

model Message {
  id String @id @default(uuid())

  text String

  sender   User?   @relation("Message_sender_User_messages", fields: [senderId], references: [id], onDelete: SetNull)
  senderId String? @map("sender_id")

  group   Group  @relation("Message_group_Group_messages", fields: [groupId], references: [id])
  groupId String @map("group_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Image {
  id String @id @default(uuid())

  url    String
  alt    String
  isMain Boolean @default(false) @map("is_main")
  order  Int

  task   Task   @relation("Task_images_Image_task", fields: [taskId], references: [id], onDelete: Cascade)
  taskId String @map("task_id")

  @@map("images")
}

model Avatar {
  id String @id @default(uuid())

  url String
  alt String

  user   User   @relation("User_avatar_Avatar_user", fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique() @map("user_id")

  @@map("avatars")
}

model Skill {
  id String @id @default(uuid())

  name       String
  isVerified Boolean @default(false) @map("is_verified")

  user User[] @relation("User_skills_Skill_userId")

  @@map("skills")
}

model Badge {
  id String @id @default(uuid())

  name String

  users User[] @relation("Badge_userId_User_badges")

  @@map("badges")
}

enum UserRole {
  ADMIN
  REGULAR
}

enum NotificationType {
  TASK_EXPIRED
  NEW_COMMENT
  GROUP_INVITE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELED
}

enum ImageType {
  USER
  TASK
}

enum MemberType {
  OWNER
  MEMBER
}
